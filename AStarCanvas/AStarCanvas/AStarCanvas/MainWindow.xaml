<Window x:Class="AStarCanvas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A* auf Canvas-Graph – Angabe"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="600"
        Background="#0b0e18">

    <Window.Resources>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"   Value="#151c2c"/>
            <Setter Property="Foreground"   Value="#8090b0"/>
            <Setter Property="BorderBrush"  Value="#252f45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="14,7"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1c2540"/>
                                <Setter Property="BorderBrush" Value="#3a4a6a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#243058"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0d1020"
                BorderBrush="#1a2035" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="A*" Foreground="#4f8ef7" FontFamily="Consolas"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Canvas Pathfinding" Foreground="#e4e8f0"
                               FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="ANGABE" Foreground="#4f8ef7" FontFamily="Consolas"
                               FontSize="10" VerticalAlignment="Center" Opacity="0.6"
                               Margin="0,0,32,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Start:" Foreground="#5a6880" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbStart" Width="160" Margin="0,0,14,0"
                              FontFamily="Consolas" FontSize="12"/>

                    <TextBlock Text="Ziel:" Foreground="#5a6880" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbEnd" Width="160" Margin="0,0,20,0"
                              FontFamily="Consolas" FontSize="12"/>

                    <Button Content="▶  Pfad suchen" Style="{StaticResource Btn}"
                            Foreground="#36d9a0" BorderBrush="#1a4a38" Background="#0e2420"
                            Click="BtnFind_Click" Margin="0,0,8,0"/>
                    <Button Content="↺  Reset" Style="{StaticResource Btn}"
                            Click="BtnReset_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas -->
            <Border Grid.Column="0" Margin="12"
                    Background="#0d1020"
                    BorderBrush="#1a2035" BorderThickness="1"
                    CornerRadius="6">
                <Canvas x:Name="GraphCanvas" ClipToBounds="True"
                        SizeChanged="GraphCanvas_SizeChanged"/>
            </Border>

            <!-- Sidebar -->
            <StackPanel Grid.Column="1" Margin="0,12,12,12">

                <!-- Legende -->
                <Border Background="#131928" BorderBrush="#1a2035"
                        BorderThickness="1" CornerRadius="4"
                        Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="LEGENDE" Foreground="#4f8ef7"
                                   FontFamily="Consolas" FontSize="10"
                                   Margin="0,0,0,10"/>

                        <StackPanel x:Name="LegendPanel"/>
                    </StackPanel>
                </Border>

                <!-- Pfad-Info -->
                <Border Background="#131928" BorderBrush="#1a2035"
                        BorderThickness="1" CornerRadius="4"
                        Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ERGEBNIS" Foreground="#4f8ef7"
                                   FontFamily="Consolas" FontSize="10"
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="PathInfo"
                                   Text="Kein Pfad berechnet."
                                   TextWrapping="Wrap"
                                   Foreground="#5a6880"
                                   FontFamily="Consolas" FontSize="11"
                                   LineHeight="18"/>
                        <TextBlock x:Name="CostInfo"
                                   Foreground="#f7c34f"
                                   FontFamily="Consolas" FontSize="11"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Formel -->
                <Border Background="#0e1a2e" BorderBrush="#1a3058"
                        BorderThickness="1" CornerRadius="4"
                        Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="FORMEL" Foreground="#4f8ef7"
                                   FontFamily="Consolas" FontSize="10"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="f(n) = g(n) + h(n)"
                                   Foreground="#4f8ef7"
                                   FontFamily="Consolas" FontSize="13"
                                   TextAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock FontFamily="Consolas" FontSize="11"
                                   Foreground="#404e6a" LineHeight="18">
                            <Run Foreground="#36d9a0">g(n)</Run>
                            <Run> Kosten vom Start&#x0a;</Run>
                            <Run Foreground="#f7c34f">h(n)</Run>
                            <Run> Eukl. Distanz zum Ziel&#x0a;</Run>
                            <Run Foreground="#4f8ef7">f(n)</Run>
                            <Run> Gesamtbewertung</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Adjazenz-Hinweis -->
                <Border Background="#131928" BorderBrush="#1a2035"
                        BorderThickness="1" CornerRadius="4"
                        Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="DATENSTRUKTUR" Foreground="#4f8ef7"
                                   FontFamily="Consolas" FontSize="10"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#404e6a"
                                   FontFamily="Consolas" FontSize="10"
                                   LineHeight="16">
                            <Run Foreground="#8090b0">_adjacency</Run>
                            <Run>&#x0a;Dictionary&#x0a;  int (Node.Id)&#x0a;  → List&lt;(Node,double)&gt;</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0d1020"
                BorderBrush="#1a2035" BorderThickness="0,1,0,0"
                Padding="16,7">
            <TextBlock x:Name="StatusBar"
                       Text="Wähle Start und Ziel, dann ▶ Pfad suchen."
                       Foreground="#404e6a"
                       FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</Window>
