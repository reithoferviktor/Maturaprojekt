<Window x:Class="Client.LoadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Route laden" Height="320" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="12">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Button Content="Abbrechen" Width="80" Margin="0,0,8,0" Click="btnAbbrechen_Click"/>
            <Button Content="Laden" Width="80" IsDefault="True" Click="btnOk_Click"/>
        </StackPanel>
        <TextBlock Text="Gespeicherte Routen:" DockPanel.Dock="Top" Margin="0,0,0,4"/>
        <ListBox x:Name="lbRouten" DisplayMemberPath="Name"/>
    </DockPanel>
</Window>
