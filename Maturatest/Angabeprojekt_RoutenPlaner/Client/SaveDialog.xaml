<Window x:Class="Client.SaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Route speichern" Height="140" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="12">
        <TextBlock Text="Name fuer die Route:" Margin="0,0,0,4"/>
        <TextBox x:Name="txtName" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Width="80" Margin="0,0,8,0" Click="btnAbbrechen_Click"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="btnOk_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
